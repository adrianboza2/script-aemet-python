# ============================================================
# AEMET Monitor — Variables de entorno
# Copia este archivo como .env y rellena tus valores.
# NUNCA subas el .env real a GitHub.
# ============================================================

# --- OBLIGATORIAS ---
AEMET_EMAIL_FROM=tu_email@gmail.com
AEMET_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx   # App Password de Gmail

# --- OPCIONALES ---
# URL del feed RSS AEMET (por defecto Madrid zona 722802)
# AEMET_RSS_URL=https://www.aemet.es/documentos_d/eltiempo/prediccion/avisos/rss/CAP_AFAZ722802_RSS.xml

# Habilitar envío de email (True/False)
# AEMET_EMAIL=True

# Reproducir sonido en alertas — solo Windows (True/False)
# AEMET_SOUND=False

# Notificar cuando un aviso baja de nivel (True/False)
# AEMET_NOTIFY_DOWNGRADE=True

# Notificar cuando un aviso desaparece del feed (True/False)
# AEMET_NOTIFY_RESOLVED=True
